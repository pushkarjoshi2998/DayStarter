<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

  <div class="bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <div class="dashboard">

    <header class="topbar glass">
      <div class="greeting-block">
        <p class="greeting-sub" id="greeting-sub">Good Morning</p>
        <h1 class="greeting-name" id="greeting-name">Hey, <%= name %> 👋</h1>
      </div>

      <form class="search-bar" action="https://www.google.com/search" method="GET" target="_blank">
        <span class="search-icon">🔍</span>
        <input type="text" name="q" placeholder="Search Google..." class="search-input" />
        <button type="submit" class="search-btn">Go</button>
      </form>

      <div class="topbar-right">
        <div class="clock-block">
          <div class="clock" id="clock">00:00:00</div>
          <div class="date" id="date">Monday, 1 Jan 2025</div>
        </div>
        <a href="/logout" class="logout-btn">Logout</a>
      </div>
    </header>

    <main class="grid">

      <section class="card glass widget-weather" id="widget-weather">
        <div class="card-label">Weather</div>
        <div class="weather-main">
          <div class="weather-icon" id="weather-icon">⛅</div>
          <div class="weather-temp" id="weather-temp">--°C</div>
        </div>
        <div class="weather-desc" id="weather-desc">Fetching weather...</div>
        <div class="weather-meta">
          <span id="weather-location">📍 Detecting location...</span>
          <span id="weather-humidity">💧 --%</span>
          <span id="weather-wind">💨 -- km/h</span>
        </div>
      </section>

      <section class="card glass widget-quote" id="widget-quote">
        <div class="card-label">Quote of the Day</div>
        <blockquote class="quote-text" id="quote-text">
          Loading your daily quote...
        </blockquote>
        <cite class="quote-author" id="quote-author">— &nbsp;</cite>
      </section>

      <section class="card glass widget-news" id="widget-news">
        <div class="card-label">Top Headlines</div>
        <div class="news-filters" id="news-filters">
          <button class="filter-btn active" data-cat="technology">Tech</button>
          <button class="filter-btn" data-cat="sports">Sports</button>
          <button class="filter-btn" data-cat="world">World</button>
          <button class="filter-btn" data-cat="entertainment">Entertainment</button>
        </div>
        <div class="news-list" id="news-list">
          <div class="news-placeholder">Fetching headlines...</div>
        </div>
      </section>

      <section class="card glass widget-todo" id="widget-todo">
        <div class="card-label">Today's Goals</div>
        <div class="todo-progress-wrap">
          <div class="todo-progress-bar" id="todo-bar" style="width: 0%"></div>
        </div>
        <p class="todo-progress-label" id="todo-label">0 of 0 done</p>
        <div class="todo-input-row">
          <input type="text" class="todo-input" id="todo-input" placeholder="Add a task..." />
          <button class="todo-add-btn" id="todo-add-btn">+</button>
        </div>
        <ul class="todo-list" id="todo-list"></ul>
      </section>

      <!-- Mini Calendar -->
      <section class="card glass widget-calendar" id="widget-calendar">
        <div class="card-label">Calendar</div>
        <div class="calendar-header">
          <button class="cal-nav" id="cal-prev">&#8592;</button>
          <span class="cal-month-label" id="cal-month-label">March 2026</span>
          <button class="cal-nav" id="cal-next">&#8594;</button>
        </div>
        <!-- single grid for both day names AND dates -->
        <div class="calendar-grid" id="calendar-grid"></div>
      </section>

    </main>
  </div>




  </div>
  <script src="/js/clock.js"></script>
  <script src="/js/weather.js"></script>
  <script src="/js/quote.js"></script>
  <script src="/js/news.js"></script>
  <script src="/js/todo.js"></script>
  <script src="/js/calendar.js"></script>
</body>

</html>